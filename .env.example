# ══════════════════════════════════════════════════════════════
#  CryptoFutures Scanner — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Binance API (leave blank for public/read-only scanning) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false          # set to "true" to use testnet

# ── Telegram Alerts ──────────────────────────────────────────
# 1. Create a bot via @BotFather → copy the token
# 2. Send a message to your bot, then:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    to find your chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ─────────────────────────────────────────────────
DB_PATH=scanner.db

# ── Scanner behaviour ────────────────────────────────────────
MIN_VOLUME_USDT=10000000       # minimum 24h volume to include a pair
MAX_PAIRS=100                  # max pairs to scan simultaneously
SCAN_INTERVAL=60               # seconds between full scan cycles
ALERT_SCORE_THRESHOLD=80       # minimum score to fire an alert (0-100)
ALERT_COOLDOWN=3600            # seconds between alerts for the same pair

# ── Data ─────────────────────────────────────────────────────
CANDLE_LOOKBACK=300            # historical candles to seed per timeframe

# ── Backtesting ──────────────────────────────────────────────
BACKTEST_START=2024-01-01
BACKTEST_END=2025-01-01
BACKTEST_TIMEFRAME=1h

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
